{
    "name": "thesimonharms/lontar",
    "description": "A minimal headless blog API package for Laravel with Markdown support.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "league/commonmark": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Lontar\\Blog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lontar\\Blog\\BlogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
